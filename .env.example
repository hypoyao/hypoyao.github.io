DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 站点域名（用于拼接微信回调地址）。线上建议设置为你的自定义域名，如 https://aiprograms.cloud
SITE_URL="http://localhost:3000"

# Cookie 签名密钥（任意长随机字符串）
AUTH_COOKIE_SECRET="please-change-me"

# 微信公众号：网页授权（微信内登录拿 openid）
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""

# （推荐）新增游戏接口鉴权：请求头 Authorization: Bearer <ADMIN_API_KEY>
ADMIN_API_KEY="please-change-me-too"

# 手机验证码登录：测试模式（1=返回 testCode；生产环境请接短信服务商）
SMS_TEST_MODE="1"
NEXT_PUBLIC_OPERATOR_NAME="奇点小匠有限责任公司"
NEXT_PUBLIC_LEGAL_EMAIL="hypoyao@qq.com"
NEXT_PUBLIC_GOVERNING_LAW="中华人民共和国法律"
NEXT_PUBLIC_DISPUTE_FORUM="广州市有管辖权的人民法院"
