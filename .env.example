DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 站点域名（用于拼接微信回调地址）。线上建议设置为你的自定义域名，如 https://aiprograms.cloud
SITE_URL="http://localhost:3000"

# Cookie 签名密钥（任意长随机字符串）
AUTH_COOKIE_SECRET="please-change-me"

# 微信公众号：网页授权（微信内登录拿 openid）
WECHAT_MP_APPID=""
WECHAT_MP_SECRET=""

# （推荐）新增游戏接口鉴权：请求头 Authorization: Bearer <ADMIN_API_KEY>
ADMIN_API_KEY="please-change-me-too"

# （可选）发布权限白名单：逗号分隔的 openid 列表（配置后只有白名单用户可发布）
ADMIN_OPENIDS=""
